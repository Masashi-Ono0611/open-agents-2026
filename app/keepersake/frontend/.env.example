NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional — once you've generated the watcher workflow on app.keeperhub.com,
# paste its detail-page URL here. The dashboard switches the indicator from
# yellow ("not configured") to green ("watching") and surfaces a "View
# workflow ↗" link.
NEXT_PUBLIC_KEEPERHUB_WORKFLOW_URL=

# Optional — match this to your workflow's schedule trigger interval (seconds).
# Drives the visual "next scheduled check" countdown on the dashboard and the
# "poll" tick cadence on the live keeper feed. The recommended setup uses 30s
# so the demo timeout (30s) and the workflow tick can land within ~1 minute.
NEXT_PUBLIC_KEEPERHUB_POLL_PERIOD=30

# Optional — the address of your KeeperHub agentic wallet (the one that signs
# execute() on the workflow's behalf). When set, KeeperSakeDelivered events
# whose `caller` matches this address are rendered in green as "KeeperHub
# delivered…", letting judges visually distinguish "the keeper did its job"
# from a manual heir-side trigger.
NEXT_PUBLIC_KEEPERHUB_KEEPER_ADDRESS=
