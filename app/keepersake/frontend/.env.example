NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional — once you've generated the watcher workflow on app.keeperhub.com,
# paste its detail-page URL here. The dashboard will show a "View workflow ↗"
# link and switch the indicator from yellow ("not configured") to green
# ("watching").
NEXT_PUBLIC_KEEPERHUB_WORKFLOW_URL=

# Optional — match this to your workflow's schedule trigger interval (seconds).
# Used purely for the visual "next scheduled check" countdown on the dashboard.
NEXT_PUBLIC_KEEPERHUB_POLL_PERIOD=60
